<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="ParallelTestSuite" verbose="1" parallel="classes" thread-count="4">
    <listeners>
        <listener class-name="core.TestListener"/>
        <listener class-name="core.RetryListener"/>
    </listeners>
    <parameter name="browser" value="chrome"/>
    <test name="AllTests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="bookstore.LoginTest"/>
            <class name="saucedemo.LoginTest"/>
        </classes>
    </test>
</suite>